rules_version = '2';

// Strict per-user ownership: every document is readable and writable only
// by the user it belongs to. AI insights and sessions are written by Cloud
// Functions (admin SDK bypasses rules) and are read-only for clients.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function ownsExisting() {
      return signedIn() && request.auth.uid == resource.data.userId;
    }

    function ownsIncoming() {
      return signedIn() && request.auth.uid == request.resource.data.userId;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /goals/{doc} {
      allow read, update, delete: if ownsExisting();
      allow create: if ownsIncoming();
    }

    match /events/{doc} {
      allow read, update, delete: if ownsExisting();
      allow create: if ownsIncoming();
    }

    match /recommendations/{doc} {
      allow read, update, delete: if ownsExisting();
      allow create: if ownsIncoming();
    }

    match /timeline/{doc} {
      allow read, update, delete: if ownsExisting();
      allow create: if ownsIncoming();
    }

    match /financialSignals/{doc} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
    }

    // Written by Cloud Functions only — clients may only read their own.
    match /insights/{doc} {
      allow read: if ownsExisting();
    }

    match /aiSessions/{doc} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
    }
  }
}
